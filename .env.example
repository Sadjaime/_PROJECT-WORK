APP_NAME=FastAPI Fintech Web App
DESCRIPTION=A portfolio fintech app for virtual trading, portfolios, and social market feeds.

# Local split database settings
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=change-me
DB_NAME=fintech_app

# Production can use either DATABASE_URL or the split DB_* values above.
# DATABASE_URL=postgresql://user:password@host:5432/database

# Comma-separated frontend origins allowed to call the API.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
